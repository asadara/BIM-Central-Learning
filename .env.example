# Required for runtime startup
JWT_SECRET=replace-with-a-long-random-secret
SESSION_SECRET=replace-with-a-long-random-secret
DB_PASSWORD=replace-with-your-db-password

# Optional database overrides
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bcl_database
DB_USER=bcl_user

# Optional legacy admin compatibility
ADMIN_TOKEN=
ADMIN_BEARER_SECRET=

# Optional bootstrap for fresh environments only
DEFAULT_ADMIN_PASSWORD=
POSTGRES_ADMIN_PASSWORD=
PGADMIN_DEFAULT_PASSWORD=

# Optional integrations
GOOGLE_CLIENT_ID=
BCL_BASE_URL=

# Optional admin password recovery email
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
ADMIN_RECOVERY_EMAIL=

PC_BIM02_USERNAME=
PC_BIM02_PASSWORD=
PC_BIM02_DRIVE=X:
