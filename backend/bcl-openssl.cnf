prompt             = no
default_md         = sha256
req_extensions     = req_ext
distinguished_name = dn

[ dn ]
C  = ID
ST = Jawa Barat
L  = Bandung
O  = BCL Studio
CN = bcl.nke.net

[ req_ext ]
subjectAltName = @alt_names

[ alt_names ]
DNS.1 = bcl.nke.net
DNS.2 = localhost
